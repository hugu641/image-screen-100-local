# ─── Server Configuration ────────────────────────────────────────────────────
# Port d'écoute du serveur (Render/Railway injectent automatiquement PORT)
PORT=5000

# ─── Security ────────────────────────────────────────────────────────────────
# Clé secrète pour la signature des jetons JWT — CHANGEZ CETTE VALEUR EN PRODUCTION !
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── Cloud Deployment ────────────────────────────────────────────────────────
# URL publique du serveur (utilisée pour les logs et la configuration TV)
# Exemple Render  : https://imagescreen-xxx.onrender.com
# Exemple Railway : https://imagescreen.up.railway.app
# Laisser vide pour un déploiement local uniquement
SERVER_URL=

# ─── CORS (Origines Autorisées) ───────────────────────────────────────────────
# En production, listez les origines autorisées séparées par des virgules.
# Laisser vide = toutes les origines acceptées (recommandé pour réseaux locaux).
# Exemple : ALLOWED_ORIGINS=https://imagescreen-xxx.onrender.com,https://mon-domaine.com
ALLOWED_ORIGINS=

# ─── Firebase / Firestore ─────────────────────────────────────────────────────
# Option 1 (recommandé en production) : chemin vers le fichier de clé de service JSON
# GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/serviceAccountKey.json
#
# Option 2 (développement local) : placez serviceAccountKey.json dans backend/
# Le fichier sera détecté automatiquement.
# ⚠️  Ne jamais committer serviceAccountKey.json dans git !

# Nom du bucket Firebase Storage (par défaut: {project-id}.appspot.com)
FIREBASE_STORAGE_BUCKET=image-screen.appspot.com
